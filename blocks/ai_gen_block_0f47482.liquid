{% doc %}
  @prompt
    I want to display all blogs dynamically on this page. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blogs-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-blogs-list__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-blogs-list__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-blogs-list__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-blogs-list__item-{{ ai_gen_id }} {
    
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blogs-list__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-blogs-list__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-blogs-list__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blogs-list__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blogs-list__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blogs-list__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-blogs-list__blog-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.blog_title_size }}px;
    color: {{ block.settings.blog_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-blogs-list__blog-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-blogs-list__blog-link-{{ ai_gen_id }}:hover .ai-blogs-list__blog-title-{{ ai_gen_id }} {
    color: {{ block.settings.blog_title_hover_color }};
  }

  .ai-blogs-list__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 14px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blogs-list__article-count-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-blogs-list__description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-blogs-list__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    transition: background-color 0.3s ease;
    margin-top: auto;
  }

  .ai-blogs-list__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-blogs-list__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-blogs-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blogs-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-blogs-list__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-blogs-list__blog-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.blog_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<blogs-list-{{ ai_gen_id }} class="ai-blogs-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-blogs-list__header-{{ ai_gen_id }}">
      <h2 class="ai-blogs-list__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if blogs.size > 0 %}
    <ul class="ai-blogs-list__grid-{{ ai_gen_id }}">
      {% for blog in blogs %}
        <li class="ai-blogs-list__item-{{ ai_gen_id }}">
          <a href="{{ blog.url }}" class="ai-blogs-list__blog-link-{{ ai_gen_id }}">
            <div class="ai-blogs-list__image-wrapper-{{ ai_gen_id }}">
              {% if blog.articles.first.image %}
                <img
                  src="{{ blog.articles.first.image | image_url: width: 600 }}"
                  alt="{{ blog.articles.first.image.alt | escape }}"
                  class="ai-blogs-list__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="400"
                >
              {% else %}
                <div class="ai-blogs-list__image-placeholder-{{ ai_gen_id }}">
                  {{ 'blog-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </a>

          <div class="ai-blogs-list__content-{{ ai_gen_id }}">
            <a href="{{ blog.url }}" class="ai-blogs-list__blog-link-{{ ai_gen_id }}">
              <h3 class="ai-blogs-list__blog-title-{{ ai_gen_id }}">{{ blog.title }}</h3>
            </a>

            {% if block.settings.show_article_count %}
              <div class="ai-blogs-list__meta-{{ ai_gen_id }}">
                <span class="ai-blogs-list__article-count-{{ ai_gen_id }}">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2H2C1.44772 2 1 2.44772 1 3V13C1 13.5523 1.44772 14 2 14H14C14.5523 14 15 13.5523 15 13V3C15 2.44772 14.5523 2 14 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M1 6H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M5 2V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {{ blog.articles_count }} {{ blog.articles_count | pluralize: 'article', 'articles' }}
                </span>
              </div>
            {% endif %}

            {% if block.settings.show_description and blog.articles.first.excerpt != blank %}
              <p class="ai-blogs-list__description-{{ ai_gen_id }}">
                {{ blog.articles.first.excerpt | strip_html | truncate: 120 }}
              </p>
            {% endif %}

            {% if block.settings.show_button %}
              <a href="{{ blog.url }}" class="ai-blogs-list__cta-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="ai-blogs-list__empty-{{ ai_gen_id }}">
      <p>No blogs found. Create your first blog to get started.</p>
    </div>
  {% endif %}
</blogs-list-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogsList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeBlogs();
      }

      initializeBlogs() {
        const items = this.querySelectorAll('.ai-blogs-list__item-{{ ai_gen_id }}');
        items.forEach((item, index) => {
          item.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('blogs-list-{{ ai_gen_id }}', BlogsList{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
