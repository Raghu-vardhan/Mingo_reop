    },
    {
      "type": "color",
      "id": "tag_hover_background",
      "label": "Hover background",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "tag_text_color",
      "label": "Text color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Blog grid"
    }
  ]
}
{% endschema %}
