{% doc %}
  @prompt
    create 3 grid blog post display.allow for individual seletion and also allow for category selection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-blog-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-blog-grid-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-blog-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-blog-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-blog-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-card-image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-blog-card-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blog-card-date-{{ ai_gen_id }},
  .ai-blog-card-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-blog-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-blog-card-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-blog-card-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.excerpt_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-blog-card-tags-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
  }

  .ai-blog-card-tag-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 12px;
    background-color: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    border-radius: 16px;
    font-size: 12px;
    text-decoration: none;
  }

  .ai-blog-card-tag-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tag_hover_background }};
  }

  .ai-blog-empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-blog-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-grid-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-blog-grid-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<blog-grid-{{ ai_gen_id }} class="ai-blog-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-blog-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-blog-grid-container-{{ ai_gen_id }}">
    {% liquid
      assign articles_to_display = ''
      assign articles_array = ''
      
      if block.settings.selection_type == 'manual'
        if block.settings.article_1 != blank
          assign articles_array = articles_array | append: block.settings.article_1.id | append: ','
        endif
        if block.settings.article_2 != blank
          assign articles_array = articles_array | append: block.settings.article_2.id | append: ','
        endif
        if block.settings.article_3 != blank
          assign articles_array = articles_array | append: block.settings.article_3.id | append: ','
        endif
      elsif block.settings.selection_type == 'blog'
        if block.settings.blog != blank
          assign blog_articles = block.settings.blog.articles
        endif
      endif
    %}

    {% if block.settings.selection_type == 'manual' %}
      {% if block.settings.article_1 != blank %}
        {% assign article = block.settings.article_1 %}
        <article class="ai-blog-card-{{ ai_gen_id }}">
          <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | escape }}"
                class="ai-blog-card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="400"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
          <div class="ai-blog-card-content-{{ ai_gen_id }}">
            {% if block.settings.show_date or block.settings.show_author %}
              <div class="ai-blog-card-meta-{{ ai_gen_id }}">
                {% if block.settings.show_date %}
                  <span class="ai-blog-card-date-{{ ai_gen_id }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    {{ article.published_at | date: '%b %d, %Y' }}
                  </span>
                {% endif %}
                {% if block.settings.show_author and article.author != blank %}
                  <span class="ai-blog-card-author-{{ ai_gen_id }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    {{ article.author }}
                  </span>
                {% endif %}
              </div>
            {% endif %}
            <h3 class="ai-blog-card-title-{{ ai_gen_id }}">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h3>
            {% if block.settings.show_excerpt and article.excerpt != blank %}
              <p class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                {{ article.excerpt | strip_html | truncate: 120 }}
              </p>
            {% endif %}
            {% if block.settings.show_tags and article.tags.size > 0 %}
              <div class="ai-blog-card-tags-{{ ai_gen_id }}">
                {% for tag in article.tags limit: 3 %}
                  <a href="{{ article.url }}#{{ tag | handle }}" class="ai-blog-card-tag-{{ ai_gen_id }}">
                    {{ tag }}
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endif %}

      {% if block.settings.article_2 != blank %}
        {% assign article = block.settings.article_2 %}
        <article class="ai-blog-card-{{ ai_gen_id }}">
          <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | escape }}"
                class="ai-blog-card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="400"
