{% doc %}
  @prompt
    Create a mobile-responsive video grid section for a Shopify theme. The section should:
    - Display videos in a single-column stacked layout on mobile (320px and below)
    - Use proper aspect ratios (16:9) for video containers on all screen sizes
    - Support autoplay with muted videos on mobile for browser compatibility
    - Include a poster/thumbnail image fallback for each video
    - Stack gracefully from multi-column grid (2-3 columns on desktop) to single column on mobile
    - Ensure video elements scale to 100% width within their containers
    - Add proper padding and spacing between video cards on mobile
    - Support both hosted video files (from Shopify Files) and external video URLs
    - Include optional text overlay or caption below each video
    - Use CSS media queries to handle breakpoints at 480px, 768px, and 1024px
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_mobile }}px 16px;
  }

  .ai-video-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-video-grid-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_mobile }}px;
  }

  .ai-video-grid-items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .ai-video-card-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #000000;
    overflow: hidden;
  }

  .ai-video-element-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-poster-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .ai-video-poster-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-poster-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-poster-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-video-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .ai-video-play-button-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 1);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-play-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    margin-left: 3px;
  }

  .ai-video-caption-{{ ai_gen_id }} {
    padding: {{ block.settings.caption_padding }}px;
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size_mobile }}px;
    text-align: {{ block.settings.caption_alignment }};
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (min-width: 480px) {
    .ai-video-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_tablet }}px 24px;
    }

    .ai-video-grid-items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-video-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_tablet }}px;
    }

    .ai-video-caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size_tablet }}px;
    }
  }

  @media screen and (min-width: 768px) {
    .ai-video-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }

    .ai-video-grid-items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap_desktop }}px;
    }

    .ai-video-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }

    .ai-video-caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size_desktop }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .ai-video-play-button-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }

    .ai-video-play-button-{{ ai_gen_id }} svg {
      width: 32px;
      height: 32px;
    }
  }
{% endstyle %}

<video-grid-{{ ai_gen_id }} class="ai-video-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-video-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-video-grid-items-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign video_enabled_key = 'video_' | append: i | append: '_enabled'
          assign video_file_key = 'video_' | append: i | append: '_file'
          assign video_url_key = 'video_' | append: i | append: '_url'
          assign poster_key = 'video_' | append: i | append: '_poster'
          assign caption_key = 'video_' | append: i | append: '_caption'

          assign video_enabled = block.settings[video_enabled_key]
          assign video_file = block.settings[video_file_key]
          assign video_url = block.settings[video_url_key]
          assign poster_image = block.settings[poster_key]
          assign caption = block.settings[caption_key]
        %}

        {% if video_enabled %}
          <div class="ai-video-card-{{ ai_gen_id }}">
            <div class="ai-video-wrapper-{{ ai_gen_id }}">
              {% if video_file != blank %}
                <video
                  class="ai-video-element-{{ ai_gen_id }}"
                  data-video-index="{{ i }}"
                  {% if block.settings.enable_autoplay %}
                    muted
                    loop
                    playsinline
                  {% endif %}
                  preload="metadata"
                >
                  <source src="{{ video_file }}" type="video/mp4">
                </video>
              {% elsif video_url != blank %}
                <video
                  class="ai-video-element-{{ ai_gen_id }}"
                  data-video-index="{{ i }}"
                  {% if block.settings.enable_autoplay %}
                    muted
                    loop
                    playsinline
                  {% endif %}
                  preload="metadata"
                >
                  <source src="{{ video_url }}" type="video/mp4">
                </video>
              {% endif %}

              {% if poster_image != blank %}
                <img
                  src="{{ poster_image | image_url: width: 800 }}"
                  alt="{{ caption | escape }}"
                  class="ai-video-poster-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ poster_image.width }}"
                  height="{{ poster_image.height }}"
                >
              {% else %}
                <div class="ai-video-poster-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if video_file == blank and video_url == blank %}
                <div class="ai-video-empty-state-{{ ai_gen_id }}">
                  Add a video file or URL
                </div>
              {% endif %}

              {% unless block.settings.enable_autoplay %}
                <button
                  class="ai-video-play-button-{{ ai_gen_id }}"
                  aria-label="Play video"
                  data-play-button="{{ i }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </button>
              {% endunless %}
            </div>

            {% if caption != blank %}
              <div class="ai-video-caption-{{ ai_gen_id }}">{{ caption }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</video-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.videos = [];
        this.autoplay = {{ block.settings.enable_autoplay | json }};
      }

      connectedCallback() {
        this.initializeVideos();
        if (this.autoplay) {
          this.setupAutoplay();
        } else {
          this.setupPlayButtons();
        }
      }

      initializeVideos() {
        this.videos = Array.from(this.querySelectorAll('.ai-video-element-{{ ai_gen_id }}'));
      }

      setupAutoplay() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target;
            const poster = video.parentElement.querySelector('.ai-video-poster-{{ ai_gen_id }}');
            
            if (entry.isIntersecting) {
              video.play().then(() => {
                if (poster) {
                  poster.classList.add('hidden');
                }
              }).catch(() => {});
            } else {
              video.pause();
              if (poster) {
                poster.classList.remove('hidden');
              }
            }
          });
        }, { threshold: 0.5 });

        this.videos.forEach((video) => {
          observer.observe(video);
        });
      }

      setupPlayButtons() {
        const playButtons = this.querySelectorAll('.ai-video-play-button-{{ ai_gen_id }}');
        
        playButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const index = button.getAttribute('data-play-button');
            const video = this.querySelector(`[data-video-index="${index}"]`);
            const poster = video.parentElement.querySelector('.ai-video-poster-{{ ai_gen_id }}');
            
            if (video) {
              video.play();
              button.classList.add('hidden');
              if (poster) {
                poster.classList.add('hidden');
              }

              video.addEventListener('ended', () => {
                button.classList.remove('hidden');
                if (poster) {
                  poster.classList.remove('hidden');
                }
              });

              video.addEventListener('pause', () => {
                if (video.currentTime === video.duration) {
                  button.classList.remove('hidden');
                  if (poster) {
                    poster.classList.remove('hidden');
                  }
                }
              });
            }
          });
        });
      }
    }

    customElements.define('video-grid-{{ ai_gen_id }}', VideoGrid{{ ai_gen_id }});
  })();
</script>

